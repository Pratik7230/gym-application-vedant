# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/gym?retryWrites=true&w=majority
MONGODB_DB_NAME=gym

# JWT (use long random strings in production)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

ATTENDANCE_TOKEN_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# OTP Auth
OTP_SECRET=
OTP_EXPIRY_MINUTES=10

# Nodemailer (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Gym App <noreply@example.com>"

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=